DATABASE_URL=postgresql://usuario:password@localhost:5432/taller_mecanico
DB_USER=usuario
DB_PASSWORD=password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=taller_mecanico
SECRET_KEY=cambia_esta_clave
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
APP_NAME=Gestion Taller Mecanico
APP_VERSION=1.0.0
DEBUG=True
# Origenes permitidos para CORS (coma-separados). Restringir en produccion.
CORS_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
# Marca la cookie de sesion como Secure (solo HTTPS). Activar en produccion.
COOKIE_SECURE=False
# Credencial del usuario admin que crea `database/seed.py`. Si no se define, el seed usa
# la clave debil por defecto (Admin123!) y marca debe_cambiar_password=True.
# OJO: el seed NO pisa la clave de un admin que ya existe en la base.
ADMIN_WEB_USER=admin
ADMIN_WEB_PASSWORD=cambia_esta_clave_admin
