# nginx — TALLERES (taller.flexconsultora.cl) -> app FastAPI en 127.0.0.1:8002.
#
# Este es el bloque HTTP INICIAL. Al correr:
#   sudo /usr/local/bin/certbot --nginx -d taller.flexconsultora.cl --agree-tos --redirect
# Certbot agrega automaticamente el bloque `listen 443 ssl`, las rutas del certificado
# y el redirect 80 -> 443. No edites a mano la parte "managed by Certbot".
#
# Instalacion:
#   sudo cp deploy/taller.conf.example /etc/nginx/conf.d/taller.conf
#   sudo nginx -t && sudo systemctl reload nginx
#   (luego certbot, como arriba)
#
# Requisito previo: registro DNS A  taller.flexconsultora.cl -> IP_DEL_SERVIDOR.

server {
    listen 80;
    listen [::]:80;
    server_name taller.flexconsultora.cl;

    client_max_body_size 10M;

    location / {
        proxy_pass         http://127.0.0.1:8002;
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
    }

    location /static/ {
        alias /home/opc/proyectos_python/TALLERES/app/static/;
        expires 7d;
    }
}
